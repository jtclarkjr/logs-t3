        {
          "name": "Get Logs by User (Created OR Updated)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/trpc/logs.getAll?input={\"json\":{\"page\":1,\"pageSize\":20,\"createdBy\":\"{{userId}}\"}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "trpc", "logs.getAll"],
              "query": [
                {
                  "key": "input",
                  "value": "{\"json\":{\"page\":1,\"pageSize\":20,\"createdBy\":\"{{userId}}\"}}"
                }
              ]
            },
            "description": "To get logs where the user either created OR updated them, you'll need to make two separate requests and merge the results client-side, OR filter by one field at a time.\n\nNote: The current API applies filters using AND logic, so specifying both createdBy and updatedBy will only return logs where the same user both created AND updated them.\n\nFor OR logic, make separate requests:\n1. Filter by createdBy\n2. Filter by updatedBy\n3. Merge and deduplicate results in your application"
          },
          "response": []
