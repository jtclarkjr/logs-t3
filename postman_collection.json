            "description": "Retrieves logs with filters. All filters use camelCase:\n- page: Page number (default 1)\n- pageSize: Items per page (default 20)\n- severity: DEBUG, INFO, WARNING, ERROR, CRITICAL\n- source: Filter by source name\n- startDate/endDate: ISO date strings\n- search: Search in message\n- sortBy: timestamp, severity, source (default: timestamp)\n- sortOrder: asc or desc (default: desc)\n- createdBy: Filter by user ID who created the log (UUID string)\n- updatedBy: Filter by user ID who last updated the log (UUID string)"
          },
          "response": [
            {
              "name": "Success Response",
              "originalRequest": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/api/trpc/logs.getAll?input={\"json\":{\"page\":1,\"pageSize\":20}}",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "trpc", "logs.getAll"]
                }
