          "name": "Get All Logs (With Filters)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/trpc/logs.getAll?input={\"json\":{\"page\":1,\"pageSize\":20,\"severity\":\"ERROR\",\"source\":\"api-server\",\"search\":\"failed\",\"sortBy\":\"timestamp\",\"sortOrder\":\"desc\"}}",
